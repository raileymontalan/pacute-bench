# Copy this file to .env and fill in the values for your environment.
# .env is gitignored — never commit it.

# Absolute path to the pacute-bench project root
export PROJECT_ROOT="/path/to/pacute-bench"
export VENV_PATH="$PROJECT_ROOT/env"
export LOGS_PATH="$PROJECT_ROOT/logs"
export RESULTS_PATH="$PROJECT_ROOT/results-202605"

# API keys (set only the providers you need).
export HF_TOKEN="HF_TOKEN"
export OPENAI_API_KEY="OPENAI_API_KEY"
export ANTHROPIC_API_KEY="ANTHROPIC_API_KEY"
export GEMINI_API_KEY="GEMINI_API_KEY"
export XAI_API_KEY="XAI_API_KEY"

# AISI API key proxy (optional).
# If running on AISI infrastructure, set the base URLs to the proxy endpoint.
# Install aisitools: pip install git+ssh://git@github.com/AI-Safety-Institute/aisi-inspect-tools.git
# The evaluator will automatically detect aisitools and wrap API keys for the proxy.
# export OPENAI_BASE_URL="https://your-aisi-proxy-endpoint/v1"
# export ANTHROPIC_BASE_URL="https://your-aisi-proxy-endpoint"
# export GEMINI_BASE_URL="https://your-aisi-proxy-endpoint"
# export XAI_BASE_URL="https://your-aisi-proxy-endpoint"
