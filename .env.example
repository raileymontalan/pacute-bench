# Copy this file to .env and fill in the values for your environment.
# .env is gitignored — never commit it.

# Absolute path to the pacute-bench project root
export PROJECT_ROOT="/path/to/pacute-bench"
export VENV_PATH="$PROJECT_ROOT/env"
export LOGS_PATH="$PROJECT_ROOT/logs"

# API keys for Hugging Face, OpenAI, and Anthropic. You can get these from the respective platforms.
export HF_TOKEN="HF_TOKEN"
export OPENAI_API_KEY="OPENAI_API_KEY"
export ANTHROPIC_API_KEY="ANTHROPIC_API_KEY"