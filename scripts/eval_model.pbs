#!/bin/bash
# PBS job script — evaluate a single model on all benchmarks.
# Do NOT run directly; submit via scripts/submit_evaluations.sh.
#
# Required PBS variable (pass with qsub -v):
#   MODEL_NAME   Short model key from configs/models_*.yaml  (e.g. qwen-2.5-7b-it)
#
# Optional PBS variables:
#   OVERWRITE    "true" to re-run benchmarks that already have results
#   MAX_SAMPLES  Integer to cap samples per benchmark (default: all)
#   VLLM_PORT    Port for the vLLM server (default: auto-derived from job ID)

#PBS -l walltime=12:00:00
#PBS -j oe
#PBS -q AISG_debug
# Note: -o and -e (log directory) are passed dynamically by submit_evaluations.sh

# ── Defaults ─────────────────────────────────────────────────────────────────
MODEL_NAME="${MODEL_NAME:-gpt2}"
OVERWRITE="${OVERWRITE:-false}"
MAX_SAMPLES="${MAX_SAMPLES:-}"
BENCHMARKS="${BENCHMARKS:-}"

# Auto-derive a unique port from PBS_JOBID so concurrent jobs don't collide.
if [[ -z "${VLLM_PORT:-}" ]]; then
    _JOBNUM="${PBS_JOBID%%.*}"
    VLLM_PORT=$(( 8000 + (_JOBNUM % 1000) ))
fi

set -euo pipefail

# PROJECT_ROOT is passed via qsub -v from submit_evaluations.sh
: "${PROJECT_ROOT:?PROJECT_ROOT must be set (pass via qsub -v or export before running)}"
cd "$PROJECT_ROOT"

# Source .env for VENV_PATH, LOGS_PATH, and API keys
# shellcheck source=.env
source "$PROJECT_ROOT/.env"
mkdir -p "$LOGS_PATH"

OUTPUT_DIR="${OUTPUT_DIR:-${RESULTS_PATH:-$LOGS_PATH}}"
mkdir -p "$OUTPUT_DIR"

source "$VENV_PATH/bin/activate"

# Set LD_LIBRARY_PATH for CUDA libs bundled in the venv
SITE_PACKAGES=$(python3 -c 'import site; print(site.getsitepackages()[0])')
export LD_LIBRARY_PATH="${SITE_PACKAGES}/nvidia/cudnn/lib:${SITE_PACKAGES}/nvidia/cusparselt/lib:${SITE_PACKAGES}/nvidia/nccl/lib:${SITE_PACKAGES}/nvidia/nvshmem/lib:${LD_LIBRARY_PATH:-}"
export PYTORCH_CUDA_ALLOC_CONF="expandable_segments:True"
export VLLM_USE_DEEP_GEMM=0

# Install package into the active venv
uv pip install -e "$PROJECT_ROOT" --quiet

# ── UUID → integer GPU remapping (PBS sets UUIDs, vLLM needs integers) ──────
UUIDS=$(echo "$CUDA_VISIBLE_DEVICES" | tr ',' '\n')
declare -a VISIBLE_DEVICES=()
for UUID in $UUIDS; do
    ID=$(nvidia-smi --id="$UUID" --query-gpu=index --format=csv,noheader 2>/dev/null || echo "$UUID")
    VISIBLE_DEVICES+=("$ID")
done
VISIBLE_DEVICES_STR=$(IFS=,; echo "${VISIBLE_DEVICES[*]}")
export CUDA_VISIBLE_DEVICES="$VISIBLE_DEVICES_STR"
N_GPUS=${#VISIBLE_DEVICES[@]}
echo "CUDA_VISIBLE_DEVICES → $CUDA_VISIBLE_DEVICES  ($N_GPUS GPUs)"

# ── Resolve all model fields from YAML ───────────────────────────────────────
_model_info=$(python3 - <<PYEOF
import yaml, sys, shlex
for cfg in ['configs/models_pt.yaml', 'configs/models_it.yaml']:
    try:
        data = yaml.safe_load(open(cfg))
        info = data['models'].get('${MODEL_NAME}')
        if info:
            print('MODEL_PATH=' + shlex.quote(str(info['path'])))
            print('MODEL_TYPE=' + shlex.quote(str(info['type'])))
            print('TP=' + shlex.quote(str(info.get('tp', 1))))
            print('REASONING_PARSER=' + shlex.quote(str(info.get('reasoning_parser', ''))))
            print('ENABLE_EXPERT_PARALLEL=' + str(info.get('enable_expert_parallel', False)).lower())
            print('LANGUAGE_MODEL_ONLY=' + str(info.get('language_model_only', False)).lower())
            print('REASONING_PARSER_PLUGIN=' + shlex.quote(str(info.get('reasoning_parser_plugin', ''))))
            print('CHAT_TEMPLATE_KWARGS=' + shlex.quote(str(info.get('chat_template_kwargs', ''))))
            default_len = 32768 if info.get('thinking') else 8192
            print('MAX_MODEL_LEN=' + shlex.quote(str(info.get('max_model_len', default_len))))
            print('ATTENTION_BACKEND=' + shlex.quote(str(info.get('attention_backend', ''))))
            print('ENFORCE_EAGER=' + str(info.get('enforce_eager', False)).lower())
            print('DISABLE_PREFIX_CACHING=' + str(info.get('disable_prefix_caching', False)).lower())
            print('DISABLE_CUSTOM_ALL_REDUCE=' + str(info.get('disable_custom_all_reduce', False)).lower())
            print('TOKENIZER_MODE=' + shlex.quote(str(info.get('tokenizer_mode', ''))))
            print('CONFIG_FORMAT=' + shlex.quote(str(info.get('config_format', ''))))
            print('LOAD_FORMAT=' + shlex.quote(str(info.get('load_format', ''))))
            print('DATA_PARALLEL_SIZE=' + shlex.quote(str(info.get('data_parallel_size', ''))))
            print('KV_CACHE_DTYPE=' + shlex.quote(str(info.get('kv_cache_dtype', ''))))
            print('BLOCK_SIZE=' + shlex.quote(str(info.get('block_size', ''))))
            print('COMPILATION_CONFIG=' + shlex.quote(str(info.get('compilation_config', ''))))
            print('MAX_CUDAGRAPH_CAPTURE_SIZE=' + shlex.quote(str(info.get('max_cudagraph_capture_size', ''))))
            print('MAX_NUM_BATCHED_TOKENS=' + shlex.quote(str(info.get('max_num_batched_tokens', ''))))
            sys.exit(0)
    except Exception:
        pass
print('MODEL_PATH=UNKNOWN')
sys.exit(1)
PYEOF
)
eval "$_model_info"

if [[ "${MODEL_PATH}" == "UNKNOWN" ]]; then
    echo "ERROR: model '${MODEL_NAME}' not found in any config YAML" >&2
    exit 1
fi
echo "Model path              : $MODEL_PATH"
echo "Model type              : $MODEL_TYPE"
echo "TP size (YAML)          : $TP"
echo "N GPUs (allocated)      : $N_GPUS"
echo "Reasoning parser        : ${REASONING_PARSER:-(none)}"
echo "Expert parallel         : $ENABLE_EXPERT_PARALLEL"
echo "Language model only     : $LANGUAGE_MODEL_ONLY"
echo "Reasoning parser plugin : ${REASONING_PARSER_PLUGIN:-(none)}"
echo "Chat template kwargs    : ${CHAT_TEMPLATE_KWARGS:-(none)}"
echo "Max model len           : $MAX_MODEL_LEN"
echo "Enforce eager           : $ENFORCE_EAGER"
echo "Disable custom allreduce: $DISABLE_CUSTOM_ALL_REDUCE"
echo "Tokenizer mode          : ${TOKENIZER_MODE:-(none)}"
echo "KV cache dtype          : ${KV_CACHE_DTYPE:-(none)}"
echo "Block size              : ${BLOCK_SIZE:-(none)}"
[[ -n "${DATA_PARALLEL_SIZE:-}" ]] && echo "Data parallel size      : $DATA_PARALLEL_SIZE"

# ── Start vLLM server ────────────────────────────────────────────────────────
_JOBNUM="${PBS_JOBID%%.*}"
VLLM_LOG="${LOGS_PATH}/vllm/${_JOBNUM}-${MODEL_NAME}.log"
mkdir -p "${LOGS_PATH}/vllm"

# Increase engine startup timeout so large models (e.g. 671B DeepSeek) don't time out
export VLLM_ENGINE_CORE_CLIENT_TIMEOUT=3600

VLLM_SERVE_ARGS=(
    "$MODEL_PATH"
    --port "$VLLM_PORT"
    --max-model-len "$MAX_MODEL_LEN"
    --gpu-memory-utilization 0.85
    --trust-remote-code
)
if [[ -n "${DATA_PARALLEL_SIZE:-}" ]]; then
    VLLM_SERVE_ARGS+=(--tensor-parallel-size 1 --data-parallel-size "$DATA_PARALLEL_SIZE")
else
    VLLM_SERVE_ARGS+=(--tensor-parallel-size "$N_GPUS")
fi
[[ "${DISABLE_PREFIX_CACHING:-}" == "true" ]] && VLLM_SERVE_ARGS+=(--no-enable-prefix-caching) \
    || VLLM_SERVE_ARGS+=(--enable-prefix-caching)
_ATTN="${ATTENTION_BACKEND:-FLASH_ATTN}"
[[ "$_ATTN" != "auto" ]] && VLLM_SERVE_ARGS+=(--attention-backend "$_ATTN")
[[ -n "${REASONING_PARSER:-}" ]]        && VLLM_SERVE_ARGS+=(--reasoning-parser "$REASONING_PARSER")
[[ -n "${REASONING_PARSER_PLUGIN:-}" ]] && VLLM_SERVE_ARGS+=(--reasoning-parser-plugin "$REASONING_PARSER_PLUGIN")
[[ -n "${CHAT_TEMPLATE_KWARGS:-}" ]]    && VLLM_SERVE_ARGS+=(--default-chat-template-kwargs "$CHAT_TEMPLATE_KWARGS")
[[ "${ENABLE_EXPERT_PARALLEL:-}" == "true" ]] && VLLM_SERVE_ARGS+=(--enable-expert-parallel)
[[ "${LANGUAGE_MODEL_ONLY:-}" == "true" ]]   && VLLM_SERVE_ARGS+=(--language-model-only)
[[ "${ENFORCE_EAGER:-}" == "true" ]]             && VLLM_SERVE_ARGS+=(--enforce-eager)
[[ "${DISABLE_CUSTOM_ALL_REDUCE:-}" == "true" ]] && VLLM_SERVE_ARGS+=(--disable-custom-all-reduce)
[[ -n "${TOKENIZER_MODE:-}" ]]               && VLLM_SERVE_ARGS+=(--tokenizer_mode "$TOKENIZER_MODE")
[[ -n "${CONFIG_FORMAT:-}" ]]                && VLLM_SERVE_ARGS+=(--config_format "$CONFIG_FORMAT")
[[ -n "${LOAD_FORMAT:-}" ]]                  && VLLM_SERVE_ARGS+=(--load_format "$LOAD_FORMAT")
[[ -n "${KV_CACHE_DTYPE:-}" ]]               && VLLM_SERVE_ARGS+=(--kv-cache-dtype "$KV_CACHE_DTYPE")
[[ -n "${BLOCK_SIZE:-}" ]]                   && VLLM_SERVE_ARGS+=(--block-size "$BLOCK_SIZE")
[[ -n "${COMPILATION_CONFIG:-}" ]]           && VLLM_SERVE_ARGS+=(--compilation-config "$COMPILATION_CONFIG")
[[ -n "${MAX_CUDAGRAPH_CAPTURE_SIZE:-}" ]]   && VLLM_SERVE_ARGS+=(--max-cudagraph-capture-size "$MAX_CUDAGRAPH_CAPTURE_SIZE")
[[ -n "${MAX_NUM_BATCHED_TOKENS:-}" ]]       && VLLM_SERVE_ARGS+=(--max-num-batched-tokens "$MAX_NUM_BATCHED_TOKENS")

echo "Starting vLLM: $MODEL_PATH (TP=$N_GPUS, port=$VLLM_PORT, max_model_len=$MAX_MODEL_LEN)"
vllm serve "${VLLM_SERVE_ARGS[@]}" > "$VLLM_LOG" 2>&1 &
VLLM_PID=$!

cleanup() {
    if [[ -n "${VLLM_PID:-}" ]]; then
        echo "Stopping vLLM server (PID $VLLM_PID)…"
        kill "$VLLM_PID" 2>/dev/null || true
        wait "$VLLM_PID" 2>/dev/null || true
    fi
}
trap cleanup EXIT INT TERM

# ── Wait for /health endpoint ────────────────────────────────────────────────
VLLM_URL="http://localhost:${VLLM_PORT}"
echo -n "Waiting for vLLM server"
ELAPSED=0; TIMEOUT=600
until curl -sf "${VLLM_URL}/health" > /dev/null 2>&1; do
    sleep 5; ELAPSED=$((ELAPSED + 5))
    echo -n "."
    if ! kill -0 "$VLLM_PID" 2>/dev/null; then
        echo " DIED — see $VLLM_LOG" >&2
        exit 1
    fi
    if [[ $ELAPSED -ge $TIMEOUT ]]; then
        echo " TIMEOUT — see $VLLM_LOG" >&2
        exit 1
    fi
done
echo " ready (${ELAPSED}s)"

# ── Detect the model ID actually registered by vLLM ─────────────────────────
REGISTERED_MODEL=$(curl -sf "${VLLM_URL}/v1/models" \
    | python3 -c "import sys,json; print(json.load(sys.stdin)['data'][0]['id'])")
echo "Registered model ID: $REGISTERED_MODEL"

# ── Build optional flags ─────────────────────────────────────────────────────
EXTRA_FLAGS=""
[[ "$OVERWRITE"   == "true" ]] && EXTRA_FLAGS="$EXTRA_FLAGS --overwrite"
[[ -n "$MAX_SAMPLES" ]]        && EXTRA_FLAGS="$EXTRA_FLAGS --max-samples $MAX_SAMPLES"
[[ -n "$BENCHMARKS" ]]         && EXTRA_FLAGS="$EXTRA_FLAGS --benchmarks ${BENCHMARKS//,/ }"

# ── Run evaluation ────────────────────────────────────────────────────────────
echo "Running evaluation for $MODEL_NAME…"
python3 -m pacute_bench.scripts.run_evaluation \
    --models "$MODEL_NAME" \
    --model-config configs/models_pt.yaml configs/models_it.yaml \
    --vllm-url "$VLLM_URL" \
    --vllm-model-id "$REGISTERED_MODEL" \
    --output-dir "$OUTPUT_DIR" \
    $EXTRA_FLAGS

echo "Done: $MODEL_NAME"
